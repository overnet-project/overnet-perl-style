#!/usr/bin/env bash
set -euo pipefail

style_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)
hooks_path="$style_root/configs/git-hooks"
perlcritic_bin=${PERLCRITIC:-}
if [ -z "$perlcritic_bin" ]; then
  perlcritic_bin=$(command -v perlcritic || true)
fi

if [ "$#" -eq 0 ]; then
  echo "usage: $0 REPO_DIR [REPO_DIR ...]" >&2
  exit 2
fi

for repo_arg in "$@"; do
  repo_root=$(git -C "$repo_arg" rev-parse --show-toplevel 2>/dev/null) || {
    echo "not a git repo: $repo_arg" >&2
    exit 1
  }
  repo_name=$(basename "$repo_root")

  git -C "$repo_root" config core.hooksPath "$hooks_path"
  echo "$repo_name: core.hooksPath=$hooks_path"

  if [ -n "$perlcritic_bin" ]; then
    git -C "$repo_root" config overnet.perlcritic.bin "$perlcritic_bin"
    echo "$repo_name: overnet.perlcritic.bin=$perlcritic_bin"
  fi
done
